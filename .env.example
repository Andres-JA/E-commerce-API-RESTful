# Copia este archivo como ".env" y ajusta los valores para tu entorno

# Cadena de conexión a PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ecommerce_db

# Seguridad JWT
SECRET_KEY=cambia-esta-clave-super-secreta-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (separados por coma). Usar "*" para permitir todo en desarrollo
BACKEND_CORS_ORIGINS=*
