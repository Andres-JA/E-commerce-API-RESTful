{
  "info": {
    "name": "E-commerce API - Grupo 2 (FastAPI)",
    "description": "Colección de pruebas para la API RESTful de e-commerce (Users, Products, Receipts).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "product_id", "value": "" },
    { "key": "receipt_id", "value": "" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"jdoe\",\n  \"email\": \"jdoe@epn.edu.ec\",\n  \"full_name\": \"John Doe\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) { pm.collectionVariables.set('token', jsonData.access_token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": "{{base_url}}/api/users/login",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "jdoe" },
                { "key": "password", "value": "secret123" }
              ]
            }
          }
        },
        {
          "name": "Get User by Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/users/{{user_id}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/users/{{user_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe Updated\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/users/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set('product_id', jsonData.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Lenovo ThinkPad\",\n  \"description\": \"Laptop para desarrollo\",\n  \"price\": 999.99,\n  \"stock\": 15\n}"
            }
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products?skip=0&limit=100"
          }
        },
        {
          "name": "Get Product by Id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products/{{product_id}}"
          }
        },
        {
          "name": "Update Product (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/products/{{product_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 949.99,\n  \"stock\": 20\n}"
            }
          }
        },
        {
          "name": "Delete Product (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/products/{{product_id}}"
          }
        }
      ]
    },
    {
      "name": "Receipts",
      "item": [
        {
          "name": "Create Receipt",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set('receipt_id', jsonData.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/receipts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"product_id\": {{product_id}}, \"quantity\": 2 }\n  ]\n}"
            }
          }
        },
        {
          "name": "List Receipts (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/receipts"
          }
        },
        {
          "name": "Get Receipt by Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/receipts/{{receipt_id}}"
          }
        },
        {
          "name": "List Receipts by User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/receipts/user/{{user_id}}"
          }
        },
        {
          "name": "Delete Receipt (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/receipts/{{receipt_id}}"
          }
        }
      ]
    }
  ]
}
